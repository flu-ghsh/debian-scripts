#!/usr/bin/env bash

set -euo pipefail

CHRONY_CONF="/etc/chrony/chrony.conf"

# Обычные ANSI-цвета
RESET=$'\033[0m'
BOLD=$'\033[1m'
RED=$'\033[31m'
GREEN=$'\033[32m'
YELLOW=$'\033[33m'
CYAN=$'\033[36m'
WHITE=$'\033[37m'

info() {
    printf '%b\n' "${CYAN}[INFO]${RESET} $*"
}

success() {
    printf '%b\n' "${GREEN}[OK]${RESET} $*"
}

warning() {
    printf '%b\n' "${YELLOW}[WARN]${RESET} $*"
}

error() {
    printf '%b\n' "${RED}[ERROR]${RESET} $*" >&2
}

section() {
    printf '\n%b\n' "${BOLD}${CYAN}===== $* =====${RESET}"
}

if [[ $EUID -ne 0 ]]; then
    error "Скрипт необходимо запускать от root."
    exit 1
fi

section "Настройка Chrony"

printf '%b' "${CYAN}Введите IP-адрес или имя NTP-сервера:${RESET} "
read -r NTP_SERVER

NTP_SERVER="$(printf '%s' "$NTP_SERVER" | xargs)"

if [[ -z "$NTP_SERVER" ]]; then
    error "Адрес NTP-сервера не указан."
    exit 1
fi

section "Проверка адреса"

if [[ "$NTP_SERVER" =~ ^([0-9]{1,3}\.){3}[0-9]{1,3}$ ]]; then
    IFS='.' read -r A B C D <<< "$NTP_SERVER"

    if (( A > 255 || B > 255 || C > 255 || D > 255 )); then
        error "Некорректный IPv4-адрес: $NTP_SERVER"
        exit 1
    fi

    success "IPv4-адрес корректен: $NTP_SERVER"
else
    if ! getent ahosts "$NTP_SERVER" >/dev/null 2>&1; then
        error "Имя $NTP_SERVER не разрешается через DNS."
        exit 1
    fi

    success "Имя $NTP_SERVER успешно разрешается."
fi

if ip route get "$NTP_SERVER" >/dev/null 2>&1; then
    success "Маршрут до NTP-сервера найден."
else
    warning "Маршрут до NTP-сервера не определён, но настройка будет продолжена."
fi

section "Установка Chrony"

if command -v chronyd >/dev/null 2>&1 && command -v chronyc >/dev/null 2>&1; then
    success "Chrony уже установлен."
else
    info "Обновляю список пакетов..."
    apt-get update

    info "Устанавливаю Chrony..."
    DEBIAN_FRONTEND=noninteractive apt-get install -y chrony

    success "Chrony установлен."
fi

if [[ ! -f "$CHRONY_CONF" ]]; then
    error "Не найден файл $CHRONY_CONF"
    exit 1
fi

section "Изменение конфигурации"

BACKUP="${CHRONY_CONF}.backup.$(date +%Y%m%d-%H%M%S)"
cp -a "$CHRONY_CONF" "$BACKUP"
success "Резервная копия: $BACKUP"

# Удаляем предыдущий управляемый блок.
sed -i \
    '/^# BEGIN MANAGED NTP SERVER$/,/^# END MANAGED NTP SERVER$/d' \
    "$CHRONY_CONF"

# Восстанавливаем ранее отключённые этим скриптом источники.
sed -i -E \
    's|^[[:space:]]*# disabled by ntp-setup: (server[[:space:]]+)|\1|' \
    "$CHRONY_CONF"

sed -i -E \
    's|^[[:space:]]*# disabled by ntp-setup: (pool[[:space:]]+)|\1|' \
    "$CHRONY_CONF"

# Отключаем активные server и pool.
sed -i -E \
    '/^[[:space:]]*#/! s|^[[:space:]]*(server[[:space:]]+)|# disabled by ntp-setup: \1|' \
    "$CHRONY_CONF"

sed -i -E \
    '/^[[:space:]]*#/! s|^[[:space:]]*(pool[[:space:]]+)|# disabled by ntp-setup: \1|' \
    "$CHRONY_CONF"

cat >> "$CHRONY_CONF" <<EOF

# BEGIN MANAGED NTP SERVER
server $NTP_SERVER iburst prefer
makestep 1.0 -1
# END MANAGED NTP SERVER
EOF

if ! chronyd -p -f "$CHRONY_CONF" >/dev/null 2>&1; then
    error "Ошибка в конфигурации Chrony."
    cp -a "$BACKUP" "$CHRONY_CONF"
    error "Восстановлена резервная копия."
    exit 1
fi

success "Конфигурация обновлена."

section "Запуск службы"

systemctl enable chrony >/dev/null 2>&1
systemctl restart chrony

if ! systemctl is-active --quiet chrony; then
    error "Служба Chrony не запустилась."
    journalctl -u chrony -n 30 --no-pager
    exit 1
fi

success "Служба Chrony запущена."

section "Синхронизация"

chronyc burst 4/4 >/dev/null 2>&1 || true

SYNC_OK=0

for ATTEMPT in $(seq 1 20); do
    SOURCE_LINE="$(
        chronyc -n sources 2>/dev/null |
        awk -v server="$NTP_SERVER" '$2 == server {print; exit}'
    )"

    STATE="$(awk '{print substr($1,2,1)}' <<< "$SOURCE_LINE")"
    REACH="$(awk '{print $5}' <<< "$SOURCE_LINE")"

    case "$STATE" in
        '*')
            success "Сервер выбран основным источником. Reach=${REACH:-0}"
            SYNC_OK=1
            break
            ;;
        '+'|'-')
            warning "Сервер отвечает. Состояние=$STATE, Reach=${REACH:-0}"
            SYNC_OK=1
            break
            ;;
        '?')
            info "Попытка $ATTEMPT/20: данных пока недостаточно, Reach=${REACH:-0}"
            ;;
        'x')
            warning "Попытка $ATTEMPT/20: время источника может быть ошибочным."
            ;;
        '~')
            warning "Попытка $ATTEMPT/20: время источника нестабильно."
            ;;
        *)
            info "Попытка $ATTEMPT/20: ожидаю ответ NTP-сервера."
            ;;
    esac

    sleep 2
done

if [[ $SYNC_OK -eq 1 ]]; then
    chronyc makestep >/dev/null 2>&1 || true
    sleep 2
    success "Команда коррекции времени выполнена."
else
    warning "Сервер пока не выбран источником времени."
    warning "Проверь UDP-порт 123 и настройки NTP-сервера."
fi

section "Результат"

date
echo
chronyc tracking || true
echo
chronyc sources -v || true

FINAL_STATE="$(
    chronyc -n sources 2>/dev/null |
    awk -v server="$NTP_SERVER" '$2 == server {print substr($1,2,1); exit}'
)"

echo

if [[ "$FINAL_STATE" == "*" ]]; then
    success "Синхронизация выполнена. Основной сервер: $NTP_SERVER"
else
    warning "Текущий статус источника: ^${FINAL_STATE:-?}"
fi
