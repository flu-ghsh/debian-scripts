#!/usr/bin/env bash

set -euo pipefail

CHRONY_CONF="/etc/chrony/chrony.conf"

if [[ $EUID -ne 0 ]]; then
    echo "Ошибка: запустите скрипт от root:"
    echo "sudo bash $0"
    exit 1
fi

read -r -p "Введите IP-адрес или имя NTP-сервера: " NTP_SERVER

if [[ -z "$NTP_SERVER" ]]; then
    echo "Ошибка: адрес NTP-сервера не указан."
    exit 1
fi

echo
echo "Проверяю адрес NTP-сервера: $NTP_SERVER"

# Проверяем, является ли значение корректным IPv4-адресом.
if [[ "$NTP_SERVER" =~ ^([0-9]{1,3}\.){3}[0-9]{1,3}$ ]]; then
    IFS='.' read -r o1 o2 o3 o4 <<< "$NTP_SERVER"

    if (( o1 > 255 || o2 > 255 || o3 > 255 || o4 > 255 )); then
        echo "Ошибка: некорректный IPv4-адрес: $NTP_SERVER"
        exit 1
    fi

    echo "Указан корректный IPv4-адрес."
else
    # Для имени сервера действительно нужна DNS-проверка.
    if ! getent ahosts "$NTP_SERVER" >/dev/null 2>&1; then
        echo "Ошибка: имя $NTP_SERVER не разрешается через DNS."
        exit 1
    fi

    echo "Имя успешно разрешается через DNS."
fi

echo
echo "Проверяю наличие маршрута до $NTP_SERVER..."

if ip route get "$NTP_SERVER" >/dev/null 2>&1; then
    ip route get "$NTP_SERVER" | head -n 1
else
    echo "Предупреждение: маршрут до $NTP_SERVER не найден."
fi

echo
echo "Устанавливаю chrony..."

apt-get update
DEBIAN_FRONTEND=noninteractive apt-get install -y chrony

if [[ ! -f "$CHRONY_CONF" ]]; then
    echo "Ошибка: файл $CHRONY_CONF не найден."
    exit 1
fi

BACKUP="${CHRONY_CONF}.backup.$(date +%Y%m%d-%H%M%S)"
cp -a "$CHRONY_CONF" "$BACKUP"

echo "Резервная копия конфигурации:"
echo "$BACKUP"

# Удаляем ранее созданный блок.
sed -i \
    '/^# BEGIN MANAGED NTP SERVER$/,/^# END MANAGED NTP SERVER$/d' \
    "$CHRONY_CONF"

# Комментируем активные внешние серверы и пулы.
sed -i -E \
    -e '/^[[:space:]]*#/! s|^[[:space:]]*(server[[:space:]]+)|# disabled by ntp-setup: \1|' \
    -e '/^[[:space:]]*#/! s|^[[:space:]]*(pool[[:space:]]+)|# disabled by ntp-setup: \1|' \
    "$CHRONY_CONF"

cat >> "$CHRONY_CONF" <<EOF

# BEGIN MANAGED NTP SERVER
server $NTP_SERVER iburst prefer
makestep 1.0 -1
# END MANAGED NTP SERVER
EOF

echo
echo "Проверяю конфигурацию chrony..."

if ! chronyd -p -f "$CHRONY_CONF" >/dev/null; then
    echo "Ошибка в конфигурации chrony."
    echo "Восстанавливаю резервную копию."
    cp -a "$BACKUP" "$CHRONY_CONF"
    exit 1
fi

echo "Включаю и перезапускаю chrony..."

systemctl enable chrony
systemctl restart chrony

echo
echo "Запрашиваю быстрые измерения у NTP-сервера..."

chronyc burst 4/4 >/dev/null || true

echo "Ожидаю получения корректных данных от сервера..."

SYNC_OK=0

for attempt in {1..15}; do
    SOURCE_STATE="$(
        chronyc -n sources 2>/dev/null |
        awk -v server="$NTP_SERVER" '$2 == server {print substr($1,2,1)}'
    )"

    REACH="$(
        chronyc -n sources 2>/dev/null |
        awk -v server="$NTP_SERVER" '$2 == server {print $5}'
    )"

    echo "Попытка $attempt/15: состояние=${SOURCE_STATE:-неизвестно}, Reach=${REACH:-0}"

    if [[ "$SOURCE_STATE" == "*" || "$SOURCE_STATE" == "+" || "$SOURCE_STATE" == "-" ]]; then
        SYNC_OK=1
        break
    fi

    sleep 2
done

echo

if [[ "$SYNC_OK" -eq 1 ]]; then
    echo "NTP-сервер отвечает. Корректирую системное время..."
    chronyc makestep
    sleep 2
else
    echo "Предупреждение: chrony пока не признал сервер пригодным."
    echo "Проверьте доступность UDP-порта 123 и настройки сервера."
fi

echo
echo "Статус синхронизации:"
chronyc tracking || true

echo
echo "Источники времени:"
chronyc sources -v || true

echo
echo "Текущее время:"
date

echo
if chronyc -n sources | grep -q "^\^\*.*${NTP_SERVER}"; then
    echo "Успешно: используется NTP-сервер $NTP_SERVER"
else
    echo "Внимание: $NTP_SERVER ещё не выбран основным источником."
    echo "Нормальный статус в chronyc sources -v: ^*"
fi
